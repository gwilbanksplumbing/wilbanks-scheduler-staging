    <link rel="apple-touch-icon" href="./icons/icon-192.png" />
    <link rel="manifest" href="./manifest.json" />

    <title>Wilbanks Company</title>

    <!-- Apply saved theme class BEFORE React hydrates, to prevent a
         flash of the wrong theme on refresh. Mirrors ThemeProvider:
         saved value wins; otherwise default to dark. -->
    <script>
      (function () {
        try {
          var saved = localStorage.getItem('wc-theme');
          var theme = (saved === 'light' || saved === 'dark') ? saved : 'dark';
          if (theme === 'dark') document.documentElement.classList.add('dark');
        } catch (e) {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>
    <!-- Auth layer must run BEFORE React mounts so window.fetch is patched to inject JWT.
         Lives at /auth-layer.js next to index.html. Required for all authenticated
         direct fetch() calls in patched.tsx and pages/*.tsx that don't pass an Authorization header. -->
    <script src="./auth-layer.js"></script>
    <script type="module" crossorigin src="./assets/index-BnLo7HeP.js"></script>
    <link rel="stylesheet" crossorigin href="./assets/index-PyTOPI5L.css">
    <style>
  html, body { background: #09090b; margin: 0; padding: 0; height: 100%; touch-action: none; }
  body { position: fixed; width: 100%; height: 100%; overflow: hidden; touch-action: none; }
  #root { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: #09090b; touch-action: none; }
  @media (min-width: 768px) {
    main { left: 256px !important; padding-top: 0 !important; }
  }
</style>
  </head>
